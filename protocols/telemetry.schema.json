{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/power10/telemetry.schema.json",
  "title": "Power10 telemetry",
  "type": "object",
  "additionalProperties": false,
  "required": ["sequence", "temperature_millicelsius", "humidity_millipercent"],
  "properties": {
    "sequence": { "type": "integer", "minimum": 0, "maximum": 4294967294 },
